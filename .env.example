# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
ENV=development

# OpenAI Configuration
OPENAI_API_KEY= your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Open Router Configuration
OPEN_ROUTER= your-open-router-api-key-here
OPEN_ROUTER_MODEL= qwen/qwen3.6-plus-preview:free
# OPEN_ROUTER_MODEL=openrouter/free

# LangChain Configuration
LANGCHAIN_API_KEY=your-langchain-api-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=customer-support-email-agent

# Email Configuration
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=Customer Support

# Database Configuration
DATABASE_URL=sqlite:///./customer_support.db
# For PostgreSQL: postgresql://user:password@localhost:5432/customer_support_db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Email Processing Configuration
EMAIL_CHECK_INTERVAL=300  # seconds
MAX_EMAILS_PER_BATCH=10
EMAIL_RESPONSE_TIMEOUT=30  # seconds

# Vector Store Configuration (if using)
VECTOR_STORE_PATH=./data/vectors
